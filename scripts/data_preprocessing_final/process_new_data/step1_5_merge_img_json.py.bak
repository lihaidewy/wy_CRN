import os
import shutil

OFFSET = 300000

# 源路径
NEW_IMG_DIR = "data/temp_data/images"
NEW_JSON_DIR = "data/temp_data/jsons"

# 目标路径
MAIN_IMG_DIR = "data/my_formatted_data/samples/CAM_FRONT"
MAIN_JSON_DIR = "data/my_formatted_data/jsons"

os.makedirs(MAIN_IMG_DIR, exist_ok=True)
os.makedirs(MAIN_JSON_DIR, exist_ok=True)

def migrate_with_offset(src_dir, dst_dir, ext):
    if not os.path.exists(src_dir):
        print(f"⚠️ 找不到路径 {src_dir}")
        return
    count = 0
    for filename in os.listdir(src_dir):
        if filename.endswith(ext):
            old_idx = int(filename.split('.')[0])
            new_idx = old_idx + OFFSET
            new_filename = f"{new_idx}{ext}"
            
            shutil.copy(os.path.join(src_dir, filename), 
                        os.path.join(dst_dir, new_filename))
            count += 1
    print(f"✅ 成功迁移并重命名 {count} 个 {ext} 文件至 {dst_dir}")

if __name__ == "__main__":
    print("🚀 开始迁移图片和标注...")
    migrate_with_offset(NEW_IMG_DIR, MAIN_IMG_DIR, ".png")
    # 如果图片是 jpg，就把上面这行的 .png 改成 .jpg
    migrate_with_offset(NEW_JSON_DIR, MAIN_JSON_DIR, ".json")
    print("🎉 步骤二：图片和 JSON 文件合并完毕！")